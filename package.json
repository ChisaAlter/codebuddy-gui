{
  "name": "codebuddy-gui",
  "version": "0.1.0",
  "description": "Electron desktop wrapper for the real CodeBuddy Web UI",
  "main": "electron/main.cjs",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "dev:vite": "vite --port 5173",
    "dev:electron": "electron .",
    "build": "vite build && electron-builder --publish never",
    "build:dir": "vite build && electron-builder --dir --publish never",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint electron src --ext .js,.jsx,.cjs",
    "lint:fix": "eslint electron src --ext .js,.jsx,.cjs --fix",
    "format": "prettier --write \"electron/**/*.{js,cjs}\" \"src/**/*.{js,jsx}\" \"tests/**/*.{js,jsx}\""
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "electron-store": "^8.2.0",
    "express": "^4.21.2",
    "monaco-editor": "^0.55.1",
    "node-fetch": "^2.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^34.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.39.4",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.38",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1",
    "vitest": "^3.2.7",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.codebuddy.gui",
    "productName": "CodeBuddy GUI",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "packElevateHelper": false,
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ]
  }
}
